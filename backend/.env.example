OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# Optional: faster/cheaper model for JD auto-fill only (defaults to OPENAI_MODEL)
# OPENAI_EXTRACT_MODEL=gpt-4o-mini

# Supabase Postgres — leave blank to use in-memory (local dev)
# Get the connection string from Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Frontend URL for CORS (deployed URL in production)
FRONTEND_URL=http://localhost:5173
