OPENAI_API_KEY=sk-your-key-here

# Primary model for LangGraph (parse follow-ups, analyze, generate, draft, role-play).
# Default: gpt-5.4-nano — see https://developers.openai.com/api/docs/models/gpt-5.4-nano
OPENAI_MODEL=gpt-5.4-nano

# Optional: override for /api/extract-fields only (defaults to OPENAI_MODEL if unset).
# Use a snapshot e.g. gpt-5.4-nano-2026-03-17 if you need pinned behavior.
# OPENAI_EXTRACT_MODEL=gpt-5.4-nano

# Supabase Postgres — leave blank to use in-memory (local dev)
# Get the connection string from Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=
# If DATABASE_URL is set but wrong (e.g. placeholder), startup fails unless you opt in:
# LANGGRAPH_MEMORY_FALLBACK=1
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Frontend URL(s) for CORS. Accepts a single origin or comma-separated list
# for multi-environment deploys (production + staging).
# For bare domains (e.g. interviewintel.ai), the server also allows the www / apex peer.
# Example: FRONTEND_URL=https://interviewintel.ai,https://staging.interviewintel.ai
FRONTEND_URL=http://localhost:5173
