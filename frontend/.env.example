# Use a dev Supabase project locally and on Vercel Preview; use production project
# only on Vercel Production. Never point Preview at prod DB if you run persisted tests.
VITE_SUPABASE_URL=https://your-dev-project.supabase.co
# Preferred key name:
VITE_SUPABASE_PUBLISHABLE_KEY=
# Backward-compatible fallback:
# VITE_SUPABASE_ANON_KEY=

# Backend public origin (no trailing slash, no /api). Set per Vercel environment:
# Preview / Development → dev Railway; Production → prod Railway.
# VITE_API_ORIGIN=https://your-service.up.railway.app

# Optional launch integrations
# VITE_STRIPE_CHECKOUT_URL=https://buy.stripe.com/...
# VITE_DEMO_VIDEO_ID=YouTubeVideoId
# VITE_ANALYTICS_PROVIDER=vercel
